{
  "name": "top-collective",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "build:api": "npm run build -w apps/api",
    "build:web": "npm run build -w apps/web",
    "build": "npm run build -w packages/database && npm run build -w apps/web",
    "db:generate": "npm run db:generate -w packages/database",
    "db:push": "npm run db:push -w packages/database",
    "db:migrate": "npm run db:migrate -w packages/database",
    "db:seed": "npm run db:seed -w packages/database",
    "lint": "npm run lint -w apps/web",
    "postinstall": "cd packages/database && npx prisma generate"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "ts-node": "^10.9.2",
    "@types/node": "^20.11.0"
  },
  "allowScripts": {
    "@prisma/client@5.22.0": true,
    "@prisma/engines@5.22.0": true,
    "prisma@5.22.0": true
  }
}
